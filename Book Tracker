import tkinter as tk
from tkinter import messagebox, ttk
import json
import os

class BookTrackerApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Book Tracker")
        self.books = []
        self.load_books()
        self.create_widgets()
        self.update_listbox()

    def create_widgets(self):
        # Поля ввода
        tk.Label(self.root, text="Название:").grid(row=0, column=0, padx=5, pady=5)
        self.title_entry = tk.Entry(self.root, width=30)
        self.title_entry.grid(row=0, column=1, padx=5, pady=5)

        tk.Label(self.root, text="Автор:").grid(row=1, column=0, padx=5, pady=5)
        self.author_entry = tk.Entry(self.root, width=30)
        self.author_entry.grid(row=1, column=1, padx=5, pady=5)

        tk.Label(self.root, text="Жанр:").grid(row=2, column=0, padx=5, pady=5)
        self.genre_entry = tk.Entry(self.root, width=30)
        self.genre_entry.grid(row=2, column=1, padx=5, pady=5)

        tk.Label(self.root, text="Страниц:").grid(row=3, column=0, padx=5, pady=5)
        self.pages_entry = tk.Entry(self.root, width=30)
        self.pages_entry.grid(row=3, column=1, padx=5, pady=5)

        # Кнопка добавления
        self.add_btn = tk.Button(self.root, text="Добавить книгу", command=self.add_book)
        self.add_btn.grid(row=4, column=0, columnspan=2, pady=10)

        # Фильтры
        self.filter_genre_var = tk.StringVar()
        self.filter_pages_var = tk.StringVar()

        ttk.Combobox(self.root, textvariable=self.filter_genre_var,
                     values=["Все"] + list(set([b["genre"] for b in self.books]))).grid(row=5, column=0, padx=5)
        ttk.Combobox(self.root, textvariable=self.filter_pages_var,
                     values=["Все", "Больше 200", "Меньше 200"]).grid(row=5, column=1, padx=5)

        self.filter_btn = tk.Button(self.root, text="Фильтровать", command=self.apply_filter)
        self.filter_btn.grid(row=6, column=0, columnspan=2, pady=5)

        # Список книг
        self.listbox = tk.Listbox(self.root, width=60, height=15)
        self.listbox.grid(row=7, column=0, columnspan=2, padx=5, pady=5)

    def add_book(self):
        title = self.title_entry.get().strip()
        author = self.author_entry.get().strip()
        genre = self.genre_entry.get().strip()
        pages = self.pages_entry.get().strip()

        if not title or not author or not genre or not pages:
            messagebox.showerror("Ошибка", "Все поля обязательны!")
            return

        if not pages.isdigit():
            messagebox.showerror("Ошибка", "Количество страниц должно быть числом!")
            return

        book = {
            "title": title,
            "author": author,
            "genre": genre,
            "pages": int(pages)
        }
        self.books.append(book)
        self.save_books()
        self.update_listbox()

    def update_listbox(self):
        self.listbox.delete(0, tk.END)
        for book in self.books:
            self.listbox.insert(tk.END,
                f"{book['title']} | {book['author']} | {book['genre']} | {book['pages']} стр.")
    
    def apply_filter(self):
        genre = self.filter_genre_var.get()
        pages_filter = self.filter_pages_var.get()

        filtered = self.books

        if genre != "Все":
            filtered = [b for b in filtered if b["genre"] == genre]
        
        if pages_filter == "Больше 200":
            filtered = [b for b in filtered if b["pages"] > 200]
        elif pages_filter == "Меньше 200":
            filtered = [b for b in filtered if b["pages"] < 200]
        
        self.listbox.delete(0, tk.END)
        for book in filtered:
            self.listbox.insert(tk.END,
                f"{book['title']} | {book['author']} | {book['genre']} | {book['pages']} стр.")
    
    def save_books(self):
        with open("books.json", "w", encoding="utf-8") as f:
            json.dump(self.books, f, ensure_ascii=False, indent=4)
    
    def load_books(self):
        if os.path.exists("books.json"):
            with open("books.json", "r", encoding="utf-8") as f:
                self.books = json.load(f)
